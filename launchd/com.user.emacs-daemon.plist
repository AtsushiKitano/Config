<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.emacs-daemon</string>

    <!-- ラッパー (scripts/emacs-daemon.sh) 経由で起動する。
         前回 daemon の dangling server socket を除去してから `emacs --fg-daemon`
         を exec するので、launchd の KeepAlive と組み合わせても起動ループしない。 -->
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>@HOME@/.conf/scripts/emacs-daemon.sh</string>
    </array>

    <!-- ログイン時に起動し、落ちたら自動で再起動 -->
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <!-- launchd 経由で起動されるプロセスは 1 プロセスあたりの fd 上限が
         既定 256 (launchctl limit maxfiles) と低い。eglot/LSP のファイル監視
         (file-notify) や大量バッファで簡単に枯渇し
           (file-error "Opening directory" "Too many open files" ...)
         になるため、fd 上限を引き上げる。 -->
    <key>SoftResourceLimits</key>
    <dict>
        <key>NumberOfFiles</key>
        <integer>65536</integer>
    </dict>
    <key>HardResourceLimits</key>
    <dict>
        <key>NumberOfFiles</key>
        <integer>65536</integer>
    </dict>

    <!-- GUI セッション (Aqua) でのみ起動する。SSH などで login しても
         Emacs daemon は立たないようにする。 -->
    <key>LimitLoadToSessionType</key>
    <string>Aqua</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>@HOME@</string>
        <key>PATH</key>
        <string>@HOMEBREW_PREFIX@/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>

    <key>StandardOutPath</key>
    <string>@HOME@/.local/log/emacs-daemon.log</string>
    <key>StandardErrorPath</key>
    <string>@HOME@/.local/log/emacs-daemon.log</string>
</dict>
</plist>
