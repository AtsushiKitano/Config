# Homebrew のパスを設定。Apple Silicon: /opt/homebrew, Intel: /usr/local。
if [ -x /opt/homebrew/bin/brew ]; then
	eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -x /usr/local/bin/brew ]; then
	eval "$(/usr/local/bin/brew shellenv)"
fi

# emacs-plus-app cask は /opt/homebrew/bin/emacs しか symlink しないため、
# emacsclient / etags / ebrowse のために Emacs.app の bin を PATH に追加する。
[ -d /Applications/Emacs.app/Contents/MacOS/bin ] && \
	path=(/Applications/Emacs.app/Contents/MacOS/bin $path)

path=(\
	$HOME/local/bin \
	$path \
	/usr/local/packages/google-cloud-sdk/bin \
	$HOME/dev/.goenv/bin \
	$HOME/.deno/bin \
	$HOME/.cargo/bin \
)

ld_library_path=(\
	$HOME/local/lib \
	/usr/local/lib \
	/usr/lib \
	/Library \
	${HOMEBREW_PREFIX:-/opt/homebrew}/lib \
	${HOMEBREW_PREFIX:-/opt/homebrew}/Library \
)

typeset -U path ld_library_path
export PATH LD_LIBRARY_PATH
export DYLD_LIBRARY_PATH=${HOMEBREW_PREFIX:-/opt/homebrew}/opt/openssl/lib

export LC_ALL=ja_JP.UTF-8
export LANG=ja_JP.UTF-8

export EDITOR=emacs
export PAGER=less

export HISTFILE=$HOME/.zsh_history
export HISTSIZE=100000
export SAVEHIST=$HISTSIZE

export TERM="xterm-256color"
export ZSH_DISABLE_COMPFIX=true


bindkey '^J' undefined-key
eval "$(mise activate zsh)"

# === fzf (Ctrl-T: ファイル選択, Alt-C: ディレクトリ移動。Ctrl-R は peco を維持) ===
if command -v fzf >/dev/null; then
	source <(fzf --zsh)
	export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
	export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
	export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'
	export FZF_DEFAULT_OPTS='--height 40% --reverse --border'
fi

# === zoxide (z でディレクトリ移動, zi でファジー選択) ===
command -v zoxide >/dev/null && eval "$(zoxide init zsh)"

# === direnv (リポジトリの .envrc を cd 時に自動ロード) ===
command -v direnv >/dev/null && eval "$(direnv hook zsh)"
