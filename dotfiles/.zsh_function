# function
function peco-history-selection(){
    BUFFER=`\\history -n 1 | tail -r | awk '!a[$0]++' | peco`
    CURSOR=$#BUFFER
    zle reset-prompt
}

function cdls (){
    \cd "$@" && ls
}

# === gcloud: 環境(構成)・プロジェクト切替 (fzf) ===
# 構成(configuration)を fzf で選んで切り替える
function gcswitch() {
    local cfg
    cfg=$(gcloud config configurations list --format="value(name)" | fzf --height 40% --reverse --prompt="gcloud config> ") || return
    [ -n "$cfg" ] && gcloud config configurations activate "$cfg"
}

# 現在の構成のプロジェクトを fzf で選んで切り替える
function gcproj() {
    local proj
    proj=$(gcloud projects list --format="value(projectId)" | fzf --height 40% --reverse --prompt="gcloud project> ") || return
    [ -n "$proj" ] && gcloud config set project "$proj"
}

# ランダムなパスワードを生成する (デフォルト8文字, -n で文字数指定)
# 生成される文字列には必ず1文字以上の特殊文字を含む
function genpass() {
    local length=8

    while [ $# -gt 0 ]; do
        case "$1" in
            -n)
                length="$2"
                shift 2
                ;;
            -h|--help)
                echo "usage: genpass [-n length]  (length は 8 以上)"
                return 0
                ;;
            *)
                echo "genpass: unknown option: $1" >&2
                echo "usage: genpass [-n length]" >&2
                return 1
                ;;
        esac
    done

    if ! [[ "$length" =~ '^[0-9]+$' ]]; then
        echo "genpass: 文字数は数値で指定してください" >&2
        return 1
    fi

    if [ "$length" -lt 8 ]; then
        echo "genpass: 文字数は 8 以上を指定してください (指定値: $length)" >&2
        return 1
    fi

    local specials='!@#$%^&*()-_=+[]{}'
    local alphanum='ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789'
    local all="$alphanum$specials"

    local pass=""
    # 少なくとも1文字は特殊文字を含める
    pass+="${specials:$((RANDOM % ${#specials})):1}"

    local i
    for (( i = 1; i < length; i++ )); do
        pass+="${all:$((RANDOM % ${#all})):1}"
    done

    # 特殊文字が先頭に固定されないようシャッフルする
    echo "$pass" | fold -w1 | sort -R | tr -d '\n'
    echo
}

# サービスアカウントの impersonation を設定 (引数なしで解除)
function gcimp() {
    if [ -z "$1" ]; then
        gcloud config unset auth/impersonate_service_account && echo "impersonation: cleared"
    else
        gcloud config set auth/impersonate_service_account "$1"
    fi
}
